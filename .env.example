# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Authentication
JWT_SECRET="generate-a-secure-32-char-random-string-here"
JWT_EXPIRES_IN="7d"

# Encryption (for OAuth tokens - generate 32 char hex)
ENCRYPTION_KEY="generate-a-secure-32-char-random-hex-string"

# Server
PORT=3000
NODE_ENV=development

# OAuth (Optional - for real OAuth flows)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
NOTION_CLIENT_ID=""
NOTION_CLIENT_SECRET=""
HUBSPOT_CLIENT_ID=""
HUBSPOT_CLIENT_SECRET=""

# OAuth Redirect URL
OAUTH_REDIRECT_URL="http://localhost:3000/api/connections/callback"

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW="1 minute"

# Redis (Optional - for BullMQ job queue)
REDIS_URL="redis://localhost:6379"