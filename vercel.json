{
  "builds": [
    { "src": "api/*.ts", "use": "@vercel/node" },
    { "src": "client/dist/**", "use": "static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/client/dist/index.html" }
  ],
  "installCommand": "npm install && cd api && npm install",
  "buildCommand": "cd client && npm install && npm run build"
}