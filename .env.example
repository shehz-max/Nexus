# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/database"

# JWT - IMPORTANT: Change this in production!
JWT_SECRET="your-super-secret-key-at-least-32-characters-long"

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
APP_URL="http://localhost:5173"
API_URL="http://localhost:3000"

# OAuth Configuration (get from respective developer portals)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
NOTION_CLIENT_ID=""
NOTION_CLIENT_SECRET=""
HUBSPOT_CLIENT_ID=""
HUBSPOT_CLIENT_SECRET=""

# OAuth Redirect URL
OAUTH_REDIRECT_URL="http://localhost:5173/api/connections/callback"

# Encryption (generate a random 32-character string)
ENCRYPTION_KEY="your-32-character-encryption-key-here"

# Redis (optional - for production queue processing)
REDIS_URL="redis://localhost:6379"