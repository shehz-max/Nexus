{
  "framework": "vite",
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "installCommand": "npm install && cd api && npm install",
  "routes": [
    { "src": "/api/auth", "dest": "/api/auth" },
    { "src": "/api/index", "dest": "/api/index" },
    { "src": "/api/webhook", "dest": "/api/webhook" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}