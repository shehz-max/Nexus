{
  "builds": [
    { "src": "api/*.ts", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/auth", "dest": "/api/auth.ts" },
    { "src": "/api/index", "dest": "/api/index.ts" },
    { "src": "/api/webhook", "dest": "/api/webhook.ts" },
    { "src": "/assets/(.*)", "dest": "/client/dist/assets/$1" },
    { "src": "/(.*)", "dest": "/client/dist/$1", "status": 200 }
  ]
}