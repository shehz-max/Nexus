{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/auth.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/webhook.ts",
      "use": "@vercel/node"
    },
    {
      "src": "client/dist/**",
      "use": "static"
    }
  ],
  "routes": [
    {
      "src": "/api/index",
      "dest": "/api/index"
    },
    {
      "src": "/api/auth",
      "dest": "/api/auth"
    },
    {
      "src": "/api/webhook",
      "dest": "/api/webhook"
    },
    {
      "src": "/(.*)",
      "dest": "/client/dist/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ]
}